        <mxCell id="tag3" value="I/O / 存储瓶颈" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=none;strokeWidth=1;arcSize=8;fontFamily=Times New Roman;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;fillColor=#EEF5EE;" parent="1" vertex="1">
          <mxGeometry x="900" y="55" width="210" height="46" as="geometry" />
