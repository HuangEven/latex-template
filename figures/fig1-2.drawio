        <mxCell id="summary" value="瓶颈迁移：&lt;font&gt;CPU&lt;/font&gt;计算 → 显存与数据搬运 → &lt;font&gt;I/O&lt;/font&gt;带宽与串行化 → 多设备通信与归并" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEF5EE;strokeColor=default;strokeWidth=1;arcSize=4;fontFamily=Times New Roman;fontSize=28;fontStyle=1;align=center;verticalAlign=middle;dashed=1;" parent="1" vertex="1">
